# Copy this file to .env and fill in your values
VITE_ETSY_API_KEY=
VITE_ETSY_SHOP_ID=

# No VITE_ prefix: this stays server-side (Vite dev middleware only) and is
# never bundled into client-side code.
ANTHROPIC_API_KEY=

# The single password required to log in to the dashboard. Also server-side
# only — the frontend never sees it, it just posts a guess to /api/login.
APP_PASSWORD=

# Optional. Path to the SQLite database file (server/db.js). Defaults to
# ./data/shop.db if unset. On Render's free tier the filesystem is
# ephemeral, so leave this unset for now — set it once a Render Persistent
# Disk is attached, pointing at its mount path (e.g. /var/data/shop.db).
DB_PATH=

# Email reminders (server/email.js), sent via MailerSend. All four below
# are optional — if any are missing, the app still boots fine and
# /api/send-test-email just reports "email not configured yet" instead of
# crashing.
#
# Generate an API token at: MailerSend dashboard > Domains > select your
# domain > Manage > API tokens > Create token.
MAILERSEND_API_KEY=

# Must be an address on a domain verified in MailerSend (e.g.
# tasha@lularose.co, once lularose.co is verified in MailerSend under
# Email > Domains).
MAILERSEND_FROM_EMAIL=

# Optional display name for the From address. Defaults to "Shop Reminders".
MAILERSEND_FROM_NAME=

# Where reminder emails get sent — your own inbox.
REMINDER_EMAIL=

# Scheduled reminder checks (server/scheduledReminders.js). Optional — the
# /api/run-reminder-check endpoint still works without it, but ONLY when
# called with your APP_PASSWORD (fine for the manual "run today's check"
# buttons in the UI). Set this to let an external scheduler (a GitHub
# Actions workflow, cron-job.org, etc.) trigger it instead, WITHOUT
# needing your real login password pasted into a third-party service.
# Generate any long random string yourself, e.g.:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=
