# Copy this file to .env and fill in your values
VITE_ETSY_API_KEY=
VITE_ETSY_SHOP_ID=

# No VITE_ prefix: this stays server-side (Vite dev middleware only) and is
# never bundled into client-side code.
ANTHROPIC_API_KEY=

# The single password required to log in to the dashboard. Also server-side
# only — the frontend never sees it, it just posts a guess to /api/login.
APP_PASSWORD=

# Optional. Path to the SQLite database file (server/db.js). Defaults to
# ./data/shop.db if unset. On Render's free tier the filesystem is
# ephemeral, so leave this unset for now — set it once a Render Persistent
# Disk is attached, pointing at its mount path (e.g. /var/data/shop.db).
DB_PATH=

# Email reminders (server/email.js). All four below are optional — if any
# are missing, the app still boots fine and /api/send-test-email just
# reports "email not configured yet" instead of crashing.
#
# MAILERLITE_API_KEY is actually a MailerSend API token (MailerSend is the
# transactional-email sibling product to MailerLite, same account/login via
# SSO — the core MailerLite API has no simple "send one email" endpoint).
# Generate one at: MailerSend dashboard > Domains > select your domain >
# Manage > API tokens > Create token.
MAILERLITE_API_KEY=

# Must be an address on a domain verified in MailerSend. New accounts get a
# free trial domain automatically (e.g. you@trial-xxxxx.mlsender.net) that
# needs no DNS setup and can send up to 100 emails — good enough to prove
# this works today. For ongoing use, verify your own domain instead:
# MailerSend dashboard > Email > Domains > Add domain > add the shown SPF/
# DKIM/CNAME records (or let MailerSend add them automatically if your
# registrar supports it) > Finish verification.
MAILERLITE_FROM_EMAIL=

# Optional display name for the From address. Defaults to "Shop Reminders".
MAILERLITE_FROM_NAME=

# Where reminder emails get sent — your own inbox.
REMINDER_EMAIL=
